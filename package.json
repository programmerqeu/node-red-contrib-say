{
  "name": "node-red-contrib-say",
  "version": "0.2.0",
  "description": "Output node for node-red for TTS (text to speech). Requires preinstall TTS program on command line.",
  "packageManager": "pnpm@9.15.0",
  "main": "say.js",
  "scripts": {
    "test": "SAY_TEST_MODULE=test/mocks/say.js node --test test/say.test.js",
    "test:run": "SAY_TEST_MODULE=test/mocks/say.js node --test test/say.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/programmerqeu/node-red-contrib-say.git"
  },
  "keywords": [
    "node-red",
    "node",
    "tts",
    "console"
  ],
  "node-red": {
    "nodes": {
      "say": "say.js"
    }
  },
  "author": "André Lademann <andre@programmerqeu.de>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/programmerqeu/node-red-contrib-say/issues"
  },
  "homepage": "https://github.com/programmerqeu/node-red-contrib-say",
  "dependencies": {
    "say": "^0.16.0"
  },
  "devDependencies": {
    "eslint": "^10.0.3",
    "husky": "^9.1.7"
  }
}
